# VendoX Frontend — .env.example
# Copy this file to .env.local and fill in the values

# API
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Mapbox (alternative to Leaflet)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=VendoX

# Auth (if using NextAuth in addition to JWT)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here_at_least_32_chars

# Google OAuth (frontend redirect URI)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
